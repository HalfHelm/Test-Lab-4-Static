.basicText {
    font-size: 40px;
    color: rgb(255, 255, 255);
    -unity-font: url('project://database/Assets/TextMesh%20Pro/Fonts/Pixellari.ttf?fileID=12800000&guid=fe92aa47e0d3e854f9ff261b98dc9121&type=3#Pixellari');
    -unity-font-definition: initial;
    -unity-font-style: normal;
    text-shadow: 5px 5px 3px rgb(0, 0, 0);
    -unity-text-align: middle-left;
    -unity-text-outline-color: rgba(0, 0, 0, 0.47);
    -unity-text-outline-width: 2px;
    letter-spacing: 6px;
    padding-top: 0;
    padding-right: 0;
    padding-bottom: 0;
    padding-left: 0;
}

.ButtonContainerStart {
    translate: 0 780px;
}
